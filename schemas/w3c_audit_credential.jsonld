{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "gov": "https://governance.internal/vocab/ai-audit#",
    "cred": "https://www.w3.org/2018/credentials#",
    "sec": "https://w3id.org/security#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "AIComplianceAuditCredential": {
      "@id": "gov:AIComplianceAuditCredential",
      "@context": {
        "@version": 1.1,
        "@protected": true,

        "modelId": { "@id": "gov:modelId", "@type": "xsd:string" },
        "modelVersion": { "@id": "gov:modelVersion", "@type": "xsd:string" },
        "auditRunId": { "@id": "gov:auditRunId", "@type": "xsd:string" },
        "previousCredential": { "@id": "gov:previousCredential", "@type": "@id" },
        "riskTier": { "@id": "gov:riskTier", "@type": "xsd:string" },
        "runIntegrityHash": { "@id": "gov:runIntegrityHash", "@type": "xsd:string" },
        "frameworks": { "@id": "gov:frameworks", "@container": "@set" },

        "phaseResults": {
          "@id": "gov:phaseResults",
          "@container": "@list",
          "@context": {
            "@version": 1.1,
            "@protected": true,
            "phase": { "@id": "gov:phase", "@type": "xsd:string" },
            "phaseNumber": { "@id": "gov:phaseNumber", "@type": "xsd:integer" },
            "status": { "@id": "gov:phaseStatus", "@type": "xsd:string" },
            "controlVersion": { "@id": "gov:controlVersion", "@type": "xsd:string" },
            "integrityHash": { "@id": "gov:integrityHash", "@type": "xsd:string" },
            "evidenceId": { "@id": "gov:evidenceId", "@type": "xsd:string" },
            "carriedForward": { "@id": "gov:carriedForward", "@type": "xsd:boolean" },
            "articles": {
              "@id": "gov:articles",
              "@container": "@set",
              "@context": {
                "@version": 1.1,
                "@protected": true,
                "framework": { "@id": "gov:framework", "@type": "xsd:string" },
                "article": { "@id": "gov:article", "@type": "xsd:string" },
                "title": { "@id": "gov:articleTitle", "@type": "xsd:string" }
              }
            }
          }
        }
      }
    },

    "GovernanceCredentialStatus2026": {
      "@id": "gov:GovernanceCredentialStatus2026",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "statusPurpose": { "@id": "gov:statusPurpose", "@type": "xsd:string" }
      }
    }
  },

  "$comment": "JSON-LD context + shape for AI Governance audit credentials (W3C VC Data Model 2.0). Credentials MUST include: '@context' [https://www.w3.org/ns/credentials/v2, <this schema>], 'type' ['VerifiableCredential','AIComplianceAuditCredential'], 'issuer' {id: did:key, name}, 'validFrom', 'validUntil', 'credentialSubject' {id, modelId, modelVersion, auditRunId, riskTier, frameworks, phaseResults[], runIntegrityHash}, 'credentialStatus' {id, type: GovernanceCredentialStatus2026, statusPurpose: revocation}, and 'proof' {type: DataIntegrityProof, cryptosuite: eddsa-jcs-2022, created, verificationMethod: did:key#…, proofPurpose: assertionMethod, proofValue: z<base58btc(Ed25519 signature over sha256(JCS(proofOptions)) || sha256(JCS(document)))>}. This file is bundled with every deployment and is never fetched over the network."
}
